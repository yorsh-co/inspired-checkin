# Easily accessible ignore folder
.ignore/

# =========================
# Node / NPM
# =========================
node_modules/

# =========================
# VS Code
# =========================
.vscode/

# =========================
# Google Apps Script
# =========================
# Local clasp configuration (API keys, projectId, etc.)
.clasp.json

# Clasp ignore file (optional, keep if you want shared settings in repo)
# .claspignore

# Build / transpiled files (if using TypeScript or bundlers)
dist/
build/

# Apps Script project manifest can be regenerated by clasp
# (remove this line if you want to version-control it)
#appsscript.json

# =========================
# Logs & temp files
# =========================
*.log
*.zip
*.sh
*.txt

# =========================
# OS / system files
# =========================
.DS_Store
Thumbs.db
