{
  "dependencies": {
    "@types/google-apps-script": "^1.0.100",
    "ejs": "^5.0.1",
    "express": "^5.2.1"
  },
  "prettier": {
    "singleQuote": true
  },
  "scripts": {
    "devStart": "nodemon src/server.js",
    "devStartHttps": "node ./node_modules/concurrently/dist/bin/concurrently.js \"npm:dev:server\" \"npm:dev:tunnel\"",
    "dev:server": "node ./node_modules/nodemon/bin/nodemon.js src/server.js",
    "dev:tunnel": "cloudflared tunnel --url http://localhost:3000 --loglevel info 2>&1 | grep --line-buffered -o 'https://[-a-zA-Z0-9\\.]*trycloudflare.com'"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14"
  }
}
