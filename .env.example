# deploy
PORT=3000
NODE_ENV=development

APP_URL=https://yourapp.com
APP_TITLE='Your App'

# event details
EVENT_ID='uuid'
CHECKIN_QR_TOKEN='randomstring'

# auth
CHECKIN_SESSION_TTL=900 # 15 minutes
USER_SESSION_TTL=259200 # 72 hours
ADMIN_SESSION_TTL=43200 # 12 hours

# postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=inspired-checkin
POSTGRES_HOST=db
POSTGRES_PORT=5432

# redis
REDIS_HOST=cache
REDIS_PORT=6379
REDIS_PASSWORD=redis

# cloudflare turnstile captcha
TURNSTILE_SITE_KEY=abc
TURNSTILE_SECRET=123

# cloudflare tunnel 
TUNNEL_TOKEN=token